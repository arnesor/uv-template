{
  "project_name": null,
  "package_name": "{{ cookiecutter.project_name.replace('-', '_') }}",
  "friendly_name": "{{ cookiecutter.project_name.replace('-', ' ').title() }}",
  "copyright_owner": "Your Name or Organization",
  "copyright_year": "{% now 'utc', '%Y' %}",
  "author": "Your Name",
  "email": "your-email@example.com",
  "github_organization": "your-github-org-or-username",
  "version": "0.0.0",
  "license": ["MIT", "Apache-2.0", "GPL-3.0"],
  "development_status": [
    "Development Status :: 1 - Planning",
    "Development Status :: 2 - Pre-Alpha",
    "Development Status :: 3 - Alpha",
    "Development Status :: 4 - Beta",
    "Development Status :: 5 - Production/Stable",
    "Development Status :: 6 - Mature",
    "Development Status :: 7 - Inactive"
  ],
  "code_quality_level": ["Medium", "High", "Low"],
  "_copy_without_render": ["*.rst_t"],
  "_jinja2_env_vars": { "lstrip_blocks": true, "trim_blocks": true }
